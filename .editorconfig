root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{js,jsx,ts,tsx,json,css,scss,html,vue}]
indent_size = 2

[*.{py,java,c,cpp,h}]
indent_size = 4

[*.groovy]
indent_size = 4
ij_groovy_continuation_indent_size = 8
ij_groovy_label_indent_size = 4

[*.{md,txt}]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{yml,yaml}]
indent_size = 2
